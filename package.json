    "publish": true
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "clsx": "^2.1.1",
    "hono": "^4.12.3",
    "isbot": "^5.1.35",
    "lucide-react": "^0.575.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.25.6",
    "@eslint/js": "10.0.1",
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "wrangler": "4.69.0"
  },
  "private": true,
  "scripts": {
    "prebuild": "bun run format && bun run lint:fix && bun run typecheck",
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "cf-typegen:image-worker": "wrangler types --config image-worker.wrangler.json",
    "deploy": "bun run build && wrangler deploy",
    "dev": "react-router dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "bun run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "image-worker:deploy": "bun run cf-typegen:image-worker && wrangler deploy --config image-worker.wrangler.json"
  },
  "repository": {
    "url": "https://github.com/involvex/dev.git",
